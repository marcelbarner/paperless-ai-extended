###############################################################################
# Paperless-ngx settings
# Alle Optionen: https://docs.paperless-ngx.com/configuration/
###############################################################################

# UID/GID des Host-Users (fuer Write-Zugriff auf consume/)
#USERMAP_UID=1000
#USERMAP_GID=1000

# Oeffentliche URL (notwendig bei externem Zugriff / Reverse Proxy)
#PAPERLESS_URL=https://paperless.example.com

# Geheimschluessel – UNBEDINGT aendern vor produktivem Einsatz!
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
PAPERLESS_SECRET_KEY=change-me-use-a-long-random-string

# Zeitzone
PAPERLESS_TIME_ZONE=Europe/Berlin

# Standardsprache fuer OCR
PAPERLESS_OCR_LANGUAGE=deu

# Weitere OCR-Sprachen (Leerzeichen-getrennt)
# Deutsch und Englisch sind vorinstalliert
#PAPERLESS_OCR_LANGUAGES=tur ces
